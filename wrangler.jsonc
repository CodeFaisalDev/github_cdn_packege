{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "githubcdn",
  "compatibility_date": "2024-09-27",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "GITHUB_OWNER": "CodeFaisalDev",
    "GITHUB_REPO": "github_cdn",
    "GITHUB_TOKEN": ""
  }
}